# API Gateway — set these for your deployment target.
# Copy to `.env` for local dev or pass as Docker build args for cloud builds.

# --- Local Docker stack ---
# REACT_APP_API_GATEWAY_URL=http://localhost:8000
# REACT_APP_GRAPHQL_URL=http://localhost:8000/api/v1/graphql
# REACT_APP_WS_URL=ws://localhost:8000/api/v1/ws/chat

# Cloud (Render example)
REACT_APP_API_GATEWAY_URL=https://api-gateway-7j51.onrender.com
REACT_APP_GRAPHQL_URL=https://api-gateway-7j51.onrender.com/api/v1/graphql
REACT_APP_WS_URL=wss://api-gateway-7j51.onrender.com/api/v1/ws/chat

# Optional override for S3 presigned upload endpoint
# REACT_APP_UPLOAD_PRESIGN_URL=https://your-gateway.example.com/api/v1/uploads/presign-post-media
